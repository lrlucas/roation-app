# WarcraftLogs API Credentials
# Créalas en: https://www.warcraftlogs.com/api/clients/
VITE_WCL_CLIENT_ID=tu_client_id_aqui
VITE_WCL_CLIENT_SECRET=tu_client_secret_aqui

VITE_FEATURE_ROTATION=true
VITE_FEATURE_BURST=true
VITE_FEATURE_AVOIDABLE=true
VITE_FEATURE_RECAP=true

# Recap de Progreso Mítico
# Tu userID de WCL (los reports están subidos en tu cuenta personal, NO en la guild)
# y el zoneID del tier actual. También editables desde la UI del panel.
VITE_WCL_USER_ID=
VITE_WCL_ZONE_ID=
# Zona horaria IANA de la guild para agrupar noches de raid
VITE_RECAP_TIMEZONE=America/Argentina/Buenos_Aires
